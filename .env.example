# ─────────────────────────────────────────────────────────────
#  Kiroku – Environment Variables Reference
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
#
#  IMPORTANT: the Phoenix release does NOT read .env files itself — it only
#  reads real environment variables. Load .env into the process environment
#  before starting the app / running mix tasks:
#     set -a; source .env; set +a        # bash
#  Or, for systemd services, use `EnvironmentFile=/path/to/.env`.
#  For Docker/Podman, use `--env-file .env`.
# ─────────────────────────────────────────────────────────────

# ── Phoenix / Web Server ──────────────────────────────────────

# Start the HTTP server when running a release binary (set to "true" in prod)
PHX_SERVER=true

# Port the HTTP server listens on (default: 4000)
PORT=4000

# Public hostname of the server (used in URL generation)
PHX_HOST=example.com

# Secret key base – generate with: mix phx.gen.secret
# REQUIRED in production
SECRET_KEY_BASE=

# ── PostgreSQL (Primary Database) ────────────────────────────

# Full Ecto connection URL – used in production
# Format: ecto://USER:PASS@HOST/DATABASE
# REQUIRED in production. Also used by `mix ecto.create` / `ecto.migrate`
# when run with MIX_ENV=prod.
#
# Production bootstrap (from a shell with this .env loaded):
#   set -a; source .env; set +a
#   MIX_ENV=prod mix ecto.create          # creates the database (user needs CREATEDB)
#   MIX_ENV=prod mix ecto.migrate          # runs all migrations
#   MIX_ENV=prod mix run priv/repo/seeds.exs   # seeds admin + default settings
DATABASE_URL=ecto://postgres:postgres@localhost/kiroku_prod

# Database connection pool size (default: 10)
POOL_SIZE=10

# Set to "true" or "1" to enable IPv6 for the DB connection
ECTO_IPV6=false

# Encrypt the Postgres connection over TLS. Defaults to ON (recommended when
# the database lives on another host). Set to "false" only for loopback or a
# DB that does not support TLS.
ECTO_DB_SSL=true

# ── MSSQL (Legacy Thesis Import – read-only, OPTIONAL) ────────
#
# The MSSQL sync/import feature is entirely optional. Leave MSSQL_HOST
# unset (or empty) and the app runs without it — Oban cron jobs for sync
# are skipped, and the admin dashboard hides sync widgets.
#
# Set these variables only if you need to import from a legacy MSSQL
# database (e.g. migrating from an older institutional repository).

# MSSQL_HOST=localhost
# MSSQL_PORT=1433
# MSSQL_DB=LegacyThesis
# MSSQL_USER=sa
# MSSQL_PASS=

# ── File Storage ──────────────────────────────────────────────

# Storage adapter: "local" or "s3"
# Can also be set in the Admin → Settings UI (DB value takes priority)
STORAGE_ADAPTER=local

# S3 / S3-compatible storage
S3_BUCKET=kiroku-uploads
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Custom S3-compatible endpoint URL (for MinIO, Cloudflare R2, etc.)
# Leave blank to use default AWS endpoints
S3_ENDPOINT=

# Public base URL override for building file download links.
# Only needed when your public-facing domain differs from S3_ENDPOINT.
# When S3_ENDPOINT is set (MinIO, R2, etc.), public URLs are derived automatically
# as: S3_ENDPOINT/bucket/key  →  https://minio.domain.com/kiroku-uploads/items/abc/file.pdf
# Set S3_PUBLIC_URL only when you have a separate CDN/proxy in front, e.g.:
#   S3_PUBLIC_URL=https://cdn.example.com/kiroku-uploads
S3_PUBLIC_URL=

# ── Email / Mailer (optional) ──────────────────────────────────
# Can also be set in the Admin → Settings UI (DB value takes priority).
# Provider: "local" (no sending — dev/staging) or "smtp".
MAILER_PROVIDER=local
MAILER_FROM=noreply@kiroku.local
# SMTP server (used when MAILER_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Clustering (optional) ─────────────────────────────────────

# DNS-based node discovery query for multi-node deployments
# Leave blank for single-node setups
DNS_CLUSTER_QUERY=

# SSO with PAuS (Padjadjaran Authentication Service)
KIROKU_PAUS_CLIENT_ID=xxxxxxxxxxxxxxxxx
KIROKU_PAUS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIROKU_PAUS_REDIRECT_URI=http://localhost:4000/auth/paus/callback

# Background jobs
# Cron schedule for embargo lifter (default: daily at 02:00)
# EMBARGO_CRON=0 2 * * *
# Cron schedule for incremental MSSQL sync per view (default: every 6 hours).
# Only active when MSSQL_HOST is set. One job per view is enqueued.
# SYNC_CRON=0 */6 * * *
