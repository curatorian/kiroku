# Prune the build context. Podman, Docker, and other OCI builders all read
# this file (.containerignore takes precedence for Podman, but .dockerignore
# is the portable default).

# Build artifacts (regenerated inside the image)
/_build/
/deps/
/doc/
/cover/

# Compiled assets / digests (regenerated by `mix assets.deploy`)
/assets/node_modules/
/priv/static/assets/
/priv/static/cache_manifest.json

# Runtime data — never bake into the image
/priv/uploads

# Version control & tooling
/.git/
/.elixir_ls/
/.expert/

# Local secrets & env
.env
.env.prod

# Misc
erl_crash.dump
*.ez
kiroku-*.tar
sample_data_each_views.txt
.elixir_ls
Dockerfile.bak
